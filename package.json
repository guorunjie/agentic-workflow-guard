{
  "name": "agentic-workflow-guard",
  "version": "1.0.0",
  "description": "Semgrep-style scanner for AI automation workflows before agents get write access; covers CI, low-code, MCP, browser agents, SARIF, marketplace action smoke tests, benchmark schemas, safe fixes, and portable skills.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guorunjie/agentic-workflow-guard.git"
  },
  "homepage": "https://github.com/guorunjie/agentic-workflow-guard#readme",
  "bugs": {
    "url": "https://github.com/guorunjie/agentic-workflow-guard/issues"
  },
  "bin": {
    "agentic-workflow-guard": "bin/agentic-workflow-guard.js"
  },
  "scripts": {
    "test": "node --test",
    "scan": "node ./bin/agentic-workflow-guard.js scan .",
    "scan:strict": "node ./bin/agentic-workflow-guard.js scan . --profile strict",
    "benchmark": "node ./bin/agentic-workflow-guard.js benchmark",
    "benchmark:report": "node ./bin/agentic-workflow-guard.js benchmark --format json",
    "benchmark:corpus": "node ./bin/agentic-workflow-guard.js benchmark corpus --format json",
    "mcp:resources": "node ./bin/agentic-workflow-guard.js mcp resources --format json",
    "schema:report": "node ./bin/agentic-workflow-guard.js schema report",
    "schema:fix": "node ./bin/agentic-workflow-guard.js schema fix",
    "schema:rule-pack": "node ./bin/agentic-workflow-guard.js schema rule-pack",
    "schema:benchmark-corpus": "node ./bin/agentic-workflow-guard.js schema benchmark-corpus",
    "schema:benchmark-report": "node ./bin/agentic-workflow-guard.js schema benchmark-report",
    "docs:build": "node ./scripts/build-pages.js",
    "smoke:package": "node ./scripts/smoke-package.js",
    "release:check": "node ./bin/agentic-workflow-guard.js release check",
    "release:prepare": "node ./scripts/prepare-release.js",
    "release:status": "node ./scripts/release-status.js",
    "release:verify": "node ./scripts/verify-release.js",
    "release:sync": "node ./scripts/sync-static.js",
    "release:sync:check": "node ./scripts/sync-static.js --check",
    "agents": "node ./bin/agentic-workflow-guard.js agents",
    "marketplace": "node ./bin/agentic-workflow-guard.js rules --format markdown"
  },
  "keywords": [
    "ai-security",
    "automation",
    "workflow-automation",
    "github-actions",
    "bitbucket-pipelines",
    "gitlab-ci",
    "travis-ci",
    "drone-ci",
    "teamcity",
    "harness",
    "harness-ci",
    "aws-codebuild",
    "google-cloud-build",
    "circleci",
    "azure-pipelines",
    "jenkins",
    "buildkite",
    "n8n",
    "activepieces",
    "dify",
    "flowise",
    "langflow",
    "zapier",
    "make",
    "pipedream",
    "node-red",
    "airflow",
    "browser-use",
    "playwright",
    "skyvern",
    "low-code",
    "mcp",
    "ai-agents",
    "agent-skills",
    "claude-skills",
    "gemini-cli",
    "openclaw",
    "hermes-agent",
    "prompt-injection",
    "rule-packs",
    "benchmark",
    "json-schema",
    "sarif",
    "developer-tools"
  ],
  "files": [
    "bin",
    "src",
    "rules",
    "schemas",
    "mcp",
    "examples",
    "benchmarks",
    "docs",
    "docs-site",
    "scripts",
    "README.md",
    "AGENTS.md",
    "GEMINI.md",
    ".awg.example.yml",
    "skillpack.yaml",
    "skills",
    ".claude",
    ".codex",
    ".cursor",
    ".github/copilot-instructions.md",
    ".github/workflows/release.yml",
    ".gemini",
    ".openclaw",
    ".hermes",
    "LICENSE",
    "action.yml"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
