{
  "name": "agentic-workflow-guard",
  "version": "0.15.0",
  "description": "Semgrep-style scanner for AI automation workflows before agents get write access; covers CI, low-code, MCP, browser agents, SARIF, rule packs, safe fixes, and portable skills.",
  "type": "module",
  "bin": {
    "agentic-workflow-guard": "./bin/agentic-workflow-guard.js"
  },
  "scripts": {
    "test": "node --test",
    "scan": "node ./bin/agentic-workflow-guard.js scan .",
    "scan:strict": "node ./bin/agentic-workflow-guard.js scan . --profile strict",
    "benchmark": "node ./bin/agentic-workflow-guard.js benchmark",
    "mcp:resources": "node ./bin/agentic-workflow-guard.js mcp resources --format json",
    "schema:report": "node ./bin/agentic-workflow-guard.js schema report",
    "schema:fix": "node ./bin/agentic-workflow-guard.js schema fix",
    "schema:rule-pack": "node ./bin/agentic-workflow-guard.js schema rule-pack",
    "docs:build": "node ./scripts/build-pages.js",
    "agents": "node ./bin/agentic-workflow-guard.js agents",
    "marketplace": "node ./bin/agentic-workflow-guard.js rules --format markdown"
  },
  "keywords": [
    "ai-security",
    "automation",
    "workflow-automation",
    "github-actions",
    "gitlab-ci",
    "circleci",
    "azure-pipelines",
    "jenkins",
    "n8n",
    "activepieces",
    "zapier",
    "make",
    "pipedream",
    "node-red",
    "airflow",
    "browser-use",
    "playwright",
    "skyvern",
    "low-code",
    "mcp",
    "ai-agents",
    "agent-skills",
    "claude-skills",
    "gemini-cli",
    "openclaw",
    "hermes-agent",
    "prompt-injection",
    "sarif",
    "developer-tools"
  ],
  "files": [
    "bin",
    "src",
    "rules",
    "schemas",
    "mcp",
    "examples",
    "benchmarks",
    "docs",
    "docs-site",
    "scripts",
    "README.md",
    "AGENTS.md",
    "GEMINI.md",
    ".awg.example.yml",
    "skillpack.yaml",
    "skills",
    ".claude",
    ".codex",
    ".cursor",
    ".gemini",
    ".openclaw",
    ".hermes",
    "LICENSE",
    "action.yml"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
