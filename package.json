{
  "name": "agentic-workflow-guard",
  "version": "0.4.0",
  "description": "Find dangerous AI automation workflows before agents get write access; ships a portable skill pack for GitHub Actions, n8n, MCP, Claude, Codex, Gemini, OpenClaw, Hermes, Cursor, and Copilot.",
  "type": "module",
  "bin": {
    "agentic-workflow-guard": "./bin/agentic-workflow-guard.js"
  },
  "scripts": {
    "test": "node --test",
    "scan": "node ./bin/agentic-workflow-guard.js scan .",
    "benchmark": "node ./bin/agentic-workflow-guard.js benchmark",
    "agents": "node ./bin/agentic-workflow-guard.js agents",
    "marketplace": "node ./bin/agentic-workflow-guard.js rules --format markdown"
  },
  "keywords": [
    "ai-security",
    "automation",
    "workflow-automation",
    "github-actions",
    "n8n",
    "activepieces",
    "node-red",
    "airflow",
    "browser-use",
    "playwright",
    "skyvern",
    "low-code",
    "mcp",
    "ai-agents",
    "agent-skills",
    "claude-skills",
    "gemini-cli",
    "openclaw",
    "hermes-agent",
    "prompt-injection",
    "sarif",
    "developer-tools"
  ],
  "files": [
    "bin",
    "src",
    "rules",
    "examples",
    "benchmarks",
    "docs",
    "README.md",
    "AGENTS.md",
    "GEMINI.md",
    ".awg.example.yml",
    "skillpack.yaml",
    "skills",
    ".claude",
    ".codex",
    ".cursor",
    ".gemini",
    ".openclaw",
    ".hermes",
    "LICENSE",
    "action.yml"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
