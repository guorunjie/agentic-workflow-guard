{
  "name": "agentic-workflow-guard",
  "version": "0.1.0",
  "description": "Semgrep-style security scanner for AI automation workflows: GitHub Actions, n8n, MCP configs, prompt-injection paths, and risky agent tools.",
  "type": "module",
  "bin": {
    "agentic-workflow-guard": "./bin/agentic-workflow-guard.js"
  },
  "scripts": {
    "test": "node --test",
    "scan": "node ./bin/agentic-workflow-guard.js scan .",
    "marketplace": "node ./bin/agentic-workflow-guard.js rules --format markdown"
  },
  "keywords": [
    "ai-security",
    "automation",
    "workflow-automation",
    "github-actions",
    "n8n",
    "mcp",
    "ai-agents",
    "prompt-injection",
    "sarif",
    "developer-tools"
  ],
  "files": [
    "bin",
    "src",
    "rules",
    "README.md",
    "LICENSE",
    "action.yml"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
